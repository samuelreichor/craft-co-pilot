<hr>

<h2>Data Protection</h2>

<h3>Section Access</h3>
<p class="light">Configure which sections the AI can access. This works like GraphQL schema permissions.</p>

{% set sections = craft.app.entries.allSections %}

{% if sections|length %}
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>Section</th>
                <th class="thin centeralign">Blocked</th>
                <th class="thin centeralign">Read Only</th>
                <th class="thin centeralign">Read + Write</th>
            </tr>
        </thead>
        <tbody>
            {% for section in sections %}
                {% set currentAccess = settings.sectionAccess[section.uid] ?? 'readWrite' %}
                <tr>
                    <td>
                        <strong>{{ section.name }}</strong>
                        <span class="light"> &ndash; {{ section.handle }}</span>
                    </td>
                    <td class="thin centeralign">
                        <input type="radio"
                               name="sectionAccess[{{ section.uid }}]"
                               value="blocked"
                               {{ currentAccess == 'blocked' ? 'checked' }}>
                    </td>
                    <td class="thin centeralign">
                        <input type="radio"
                               name="sectionAccess[{{ section.uid }}]"
                               value="readOnly"
                               {{ currentAccess == 'readOnly' ? 'checked' }}>
                    </td>
                    <td class="thin centeralign">
                        <input type="radio"
                               name="sectionAccess[{{ section.uid }}]"
                               value="readWrite"
                               {{ currentAccess == 'readWrite' ? 'checked' }}>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="light">No sections found.</p>
{% endif %}

<br>

<h3>Plugin Data Blocklist</h3>
<p class="light">Plugins that contain sensitive user data are blocked by default. Unblock at your own risk.</p>

{% set pluginOptions = [
    { label: 'Formie (form submissions)', value: 'formie' },
    { label: 'Freeform (form submissions)', value: 'freeform' },
    { label: 'Campaign (email lists)', value: 'campaign' },
] %}

{% for option in pluginOptions %}
    {{ forms.checkboxField({
        label: option.label,
        id: 'blockedPlugin-' ~ option.value,
        name: 'blockedPlugins[]',
        value: option.value,
        checked: option.value in settings.blockedPlugins,
    }) }}
{% endfor %}

<hr>

<h2>Web Search</h2>

{{ forms.lightswitchField({
    label: 'Enable Web Search',
    instructions: "Allow the AI to search the web. Uses Anthropic's built-in web search (Brave Search). Additional costs apply. Only available for Anthropic.",
    id: 'webSearchEnabled',
    name: 'webSearchEnabled',
    on: settings.webSearchEnabled,
}) }}

<hr>

<h2>Advanced</h2>

{{ forms.textField({
