{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/web/assets/chat/src/*"]
    }
  },
  "include": ["src/web/assets/chat/src/**/*.ts", "src/web/assets/chat/src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
